<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- 书库标题 -->
    <TextView android:layout_width="match_parent" android:layout_height="42dp"
        android:gravity="center_vertical|center_horizontal" android:paddingLeft="16dp"
        android:text="书库" android:textColor="@android:color/black"
        android:textSize="20sp" android:textStyle="bold"
        android:background="#F5F5F5" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@android:color/black" />

    <!-- 书籍列表 -->
    <FrameLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <ListView android:id="@+id/book_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/black"
            android:dividerHeight="1dp"
            android:paddingTop="4dp" android:paddingBottom="4dp" />
    </FrameLayout>

    <!-- 底部按钮栏 -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@android:color/black" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5">

        <TextView android:id="@+id/btn_import"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:clickable="true"
            android:text="导入" android:textColor="@android:color/black"
            android:textSize="20sp" />
        <View android:layout_width="1dp" android:layout_height="36dp"
            android:background="@android:color/black" />

        <TextView android:id="@+id/btn_refresh_settings"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:clickable="true"
            android:text="刷新" android:textColor="@android:color/black"
            android:textSize="20sp" />
        <View android:layout_width="1dp" android:layout_height="36dp"
            android:background="@android:color/black" />

        <TextView android:id="@+id/btn_log" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:clickable="true" android:text="日志" android:textColor="@android:color/black" android:textSize="20sp" />
        <View android:layout_width="1dp" android:layout_height="36dp" android:background="@android:color/black" />

        <TextView android:id="@+id/btn_about"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:clickable="true"
            android:text="关于" android:textColor="@android:color/black"
            android:textSize="20sp" />
    </LinearLayout>

</LinearLayout>

