<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
>

    <!-- 权限声明 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 墨水屏适配：任何 DPI 都不缩放 -->
    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:anyDensity="true" />

    <application
        android:name=".EInkReaderApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="false">

        <!-- 首页：书库 -->
        <activity
            android:name=".ui.library.LibraryActivity"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="application/epub+zip" />
            </intent-filter>
        </activity>

        <!-- 阅读器页面 -->
        <activity
            android:name=".ui.reader.ReaderActivity"
            android:label="@string/reader"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize" />

        <!-- 目录页面 -->
        <activity
            android:name=".ui.reader.TocActivity"
            android:label="目录"
            android:screenOrientation="portrait" />

        <!-- 阅读设置页面 -->
        <activity
            android:name=".ui.reader.ReadingSettingsActivity"
            android:label="阅读设置"
            android:screenOrientation="portrait" />

        <!-- 文件选择页面 -->
        <activity
            android:name=".ui.library.FilePickerActivity"
            android:label="选择文件"
            android:screenOrientation="portrait" />

        <!-- 刷新设置页面 -->
        <activity
            android:name=".ui.library.RefreshSettingsActivity"
            android:label="刷新设置"
            android:screenOrientation="portrait" />

        <!-- 关于页面 -->
        <activity
            android:name=".ui.settings.AboutActivity"
            android:label="关于"
            android:screenOrientation="portrait" />

            <activity android:name=".ui.reader.DebugLogActivity"
            android:label="调试日志"
            android:screenOrientation="portrait" />

    </application>

</manifest>



